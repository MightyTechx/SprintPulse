{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["es2020", "esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "module": "esnext",
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types", "./typings"],
    "types": ["vite/client"],
    "paths": {
      "@sprintpulse/prisma": ["./gateways/src/generated/prisma/client"],
      "@sprintpulse/component": ["./libs/ui/components/index.ts"],
      "@sprintpulse/component/*": ["./libs/ui/components/*"],
      "@sprintpulse/theme": ["./libs/theme/index.ts"],
      "@sprintpulse/interfaces": ["./libs/entities/index.ts"],
      "@sprintpulse/hooks": ["./libs/ui/hooks/index.ts"],
      "@sprintpulse/utils": ["./libs/utils/index.ts"],
      "@sprintpulse/pages/*": ["./libs/ui/pages/*"],
      "@sprintpulse/constants": ["./libs/shared/constants/index.ts"],
      "@sprintpulse/middleware": ["./libs/core/middleware/index.ts"],
      "@sprintpulse/config": ["./libs/core/config/index.ts"],
      "@sprintpulse/database": ["./libs/core/database/index.ts"],
      "@sprintpulse/core": ["./libs/core/index.ts"],
      "@sprintpulse/core/repository": ["./libs/core/repository/index.ts"],
      "@sprintpulse/core/service": ["./libs/core/service/index.ts"],
      "@sprintpulse/core/validation": ["./libs/core/validation/index.ts"],
      "@sprintpulse/core/gateways": ["./libs/core/gateways/index.ts"],
      "@sprintpulse/mocks": ["./libs/ui/mocks/index.ts"],
      "@sprintpulse/services": ["./libs/services/index.ts"],
      "@sprintpulse/store": ["./libs/ui/store/index.ts"],
      "@sprintpulse/state": ["./libs/services/state/index.ts"],
      "@sprintpulse/slices": ["./libs/ui/slices/index.ts"],
      "@sprintpulse/ui-services": ["./libs/ui/services/index.ts"],
      "@sprintpulse/services/*": ["./gateways/src/services/*"]
    }
  },
  "exclude": ["dist", "node_modules", "temp"]
}
