{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "types": ["node", "jest"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "outDir": "../../dist/out-tsc/shared",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@sprintpulse/prisma": ["../gateways/src/generated/prisma/client"],
      "@sprintpulse/theme": ["./theme/index.ts"],
      "@sprintpulse/interfaces": ["./entities/index.ts"],
      "@sprintpulse/hooks": ["./ui/hooks/index.ts"],
      "@sprintpulse/utils": ["./utils/index.ts"],
      "@sprintpulse/services": ["./services/index.ts"],
      "@sprintpulse/config": ["./core/config/index.ts"],
      "@sprintpulse/core": ["./core/index.ts"],
      "@sprintpulse/component": ["./ui/components/index.ts"],
      "@sprintpulse/component/*": ["./ui/components/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../libs/vite-env.d.ts",
    "../typings/vite-env.d.ts",
    "../gateways/src/generated/prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ]
}
