# ================================
# SerivceOps - Environment Variables Template
# ================================
# Copy this file to .env and fill in the actual values
# This file is safe to commit to version control
# Last Updated: 2026-01-29
# ================================

# ============================================
# BACKEND SERVER CONFIGURATION
# ============================================

# Environment
NODE_ENV=production

# Server (Unified API on single port)
PORT=3600
HOST=localhost

# Database
# Note: Special characters in password must be URL-encoded (& becomes %26)
DATABASE_URL=postgresql://postgres.wxodwelashcsxeartona:SprintPulse20267013@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
DB_PASSWORD=SprintPulse20267013

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Redis (Optional - Server starts without Redis if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
ENABLE_CONSOLE_LOGS=true

# CORS
CORS_ORIGIN=http://localhost:3400,http://localhost:3400,https://sprintpulse.tech,https://www.sprintpulse.tech

# ============================================
# EMAIL / SMTP CONFIGURATION
# ============================================
# For Gmail: Use an App Password (not regular password)
# 1. Enable 2FA on your Google account
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=SerivceOps App <noreply@sprintpulse.tech>

# ============================================
# API ENDPOINTS (For Reference)
# ============================================
# Admin API: http://localhost:3600/api/admin
# User API: http://localhost:3600/api/user
# Swagger Docs: http://localhost:3600/api/docs

# ============================================
# FRONTEND PORTS (For Reference)
# ============================================
# Admin Apps: http://localhost:3400
# User Apps: http://localhost:3400

# ============================================
# LOCATION SEARCH (Geoapify)
# ============================================
# Sign up at https://myprojects.geoapify.com/register to get a free API key
# Free tier: 3,000 credits/day
VITE_GEOAPIFY_API_KEY=your-geoapify-api-key-here

# ============================================
# GOOGLE GEMINI AI (Chat Assistant)
# ============================================
# Sign up at https://ai.google.dev/ to get a free API key
# Free tier available with generous token limits
# Get your API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# WHATSAPP BUSINESS API (360dialog Partner)
# ============================================
# Sign up for free at https://hub.360dialog.com/
# Alternative: Use Meta's official WhatsApp Business API
# WhatsApp is in DEMO MODE by default (logs to console)
# Set WHATSAPP_API_KEY and WHATSAPP_PHONE_NUMBER_ID to enable real sending
WHATSAPP_API_URL=https://api.360dialog.com/v1
WHATSAPP_API_KEY=your_360dialog_api_key_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_TEMPLATE_NAMESPACE=your_template_namespace
